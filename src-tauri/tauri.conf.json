{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HymnBeam",
  "version": "0.1.3",
  "identifier": "com.hymnbeam.app",
  "build": {
    "frontendDist": "../frontend",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HymnBeam — Operator",
        "label": "operator",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "public.app-category.productivity",
    "shortDescription": "Church song lyrics projector",
    "longDescription": "HymnBeam projects song lyrics to a screen for church congregations. Dual-window operator/projector layout, multi-monitor routing, keyboard-first control, and a portable SQLite song library.",
    "copyright": "Copyright © 2026 HymnBeam",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 },
        "windowSize": { "width": 660, "height": 420 }
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
